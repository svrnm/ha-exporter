# Copy to .env and edit.

# HTTP port to listen on.
PORT=8080

# Bind address. 127.0.0.1 is safest behind a reverse proxy.
HOST=0.0.0.0

# Browser / GET API — plaintext or sha256$… fingerprint (see npm run generate-tokens).
# Clients always send the plaintext bearer token.
HA_EXPORTER_READ_TOKEN=change-me-read
# Home Assistant uploads + DELETE /instances — same formats as read token.
HA_EXPORTER_WRITE_TOKEN=change-me-write

# Recommended: `cd server && npm run generate-tokens` writes sha256$ fingerprints.

# SQLite file path. If unset, defaults to <server>/data/ha-exporter.sqlite
# resolved relative to the source tree (not the CWD), so it works the same
# whether launched via `npm start`, systemd, or anywhere else.
# DATABASE_PATH=/absolute/path/to/ha-exporter.sqlite

# Max JSON body size. Payloads are gzipped, but inflated bodies can still be
# large during backfill. Bump if you see 413 errors.
BODY_LIMIT=50mb

# Location of the built React UI. Defaults to ../web/dist relative to the
# server source tree. If the folder doesn't exist the server still boots
# API-only, so you can ignore this until you've run `npm run build` in web/.
# WEB_ROOT=/absolute/path/to/web/dist
